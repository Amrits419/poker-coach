generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  username  String        @unique
  createdAt DateTime      @default(now())
  hands     TrainerHand[]
}

model TrainerHand {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  setup       Json
  scenario    Json
  userActions Json
  analysis    Json?
  leaks       String[]
  createdAt   DateTime @default(now())
}
