generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  createdAt DateTime @default(now())
  hands     Hand[]
}

model Hand {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  position  String
  holeCards String
  board     String
  actions   Json
  potSize   Float
  stackSize Float
  analysis  Json
  leaks     String[]
  createdAt DateTime @default(now())
}
